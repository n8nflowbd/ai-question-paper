{
  "version": 2,
  "routes": [
    {
      "src": "/api/auth",
      "dest": "api/auth.js"
    },
    {
      "src": "/api/generate",
      "dest": "api/generate.js"
    },
    {
      "src": "/api/payment",
      "dest": "api/payment.js"
    },
    {
      "src": "/api/status/(.*)",
      "dest": "api/status.js"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
